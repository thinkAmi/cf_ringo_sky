{
  "compilerOptions": {
    // Enable latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    // Cloudflare の型は wrangler types 生成の worker-configuration.d.ts で供給する
    "types": []
  },
  // scripts/ は bun 実行専用の開発スクリプト(bun:sqlite 等)。Worker(CF ランタイム)の
  // 型環境とは文脈が異なるため、型チェック対象から除外する。
  "exclude": ["scripts"]
}
